# Copy this file to .env and fill in your values.
# docker-compose will automatically load .env from the project root.

# Local development only — not used in production.
# The site will be available at http://localhost:HOST_PORT
HOST_PORT=8080

# Deployment target (used by scripts/deploy.sh)
DEPLOY_HOST=your-droplet-ip-or-hostname
DEPLOY_USER=root
DEPLOY_PATH=/opt/isitbensbirthday
DEPLOY_BRANCH=main
